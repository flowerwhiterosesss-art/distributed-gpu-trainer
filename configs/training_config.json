{
    "model": {
        "name": "meta-llama/Llama-3.1-8B",
        "type": "causal_lm",
        "hidden_size": 4096,
        "num_layers": 32,
        "num_heads": 32
    },
    "training": {
        "epochs": 3,
        "batch_size": 4,
        "learning_rate": 2e-5,
        "warmup_steps": 100,
        "max_seq_length": 2048,
        "gradient_accumulation_steps": 4,
        "mixed_precision": "bf16",
        "distributed": true
    },
    "data": {
        "dataset": "tatsu-lab/alpaca",
        "split": "train",
        "max_samples": 52000
    },
    "checkpointing": {
        "save_every_n_steps": 500,
        "keep_last_n": 3,
        "output_dir": "./checkpoints"
    }
}
